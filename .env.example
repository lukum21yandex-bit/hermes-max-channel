# MAX Bot Token — get from @MasterBot in MAX
MAX_TOKEN=YOUR_MAX_BOT_TOKEN_HERE

# Optional: comma-separated list of user IDs allowed to use bot
# Leave empty for public bot (anyone can interact)
# ALLOWED_USER_IDS=123456789,987654321

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# --- Webhook mode (for VPS deployment) ---
# WEBHOOK_SECRET=your_random_secret_string_5-256_chars
# WEBHOOK_URL=https://your-domain.ru/webhook
